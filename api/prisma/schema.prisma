generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exhibition {
  exhibitionId BigInt    @id @default(autoincrement()) @map("exhibition_id")
  title        String    @unique @db.VarChar(255)
  description  String?
  statusId     Int?      @map("status_id")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  exhibits     Exhibit[]
  status       Status?   @relation(fields: [statusId], references: [statusId], onUpdate: NoAction)
  images       Image[]

  @@map("exhibitions")
}

model Exhibit {
  exhibitId             BigInt      @id @default(autoincrement()) @map("exhibit_id")
  exhibitionId          BigInt?     @map("exhibition_id")
  badgeId               BigInt?     @unique @map("badge_id")
  title                 String      @db.VarChar(255)
  statusId              Int?        @map("status_id")
  description           String?
  additionalDescription String?     @map("additional_description")
  sequence              Int?        @map("sequence")
  createdAt             DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  audio                 Audio[]
  badge                 Badge?      @relation("ExhibitToBadge", fields: [badgeId], references: [badgeId], onUpdate: NoAction)
  exhibition            Exhibition? @relation(fields: [exhibitionId], references: [exhibitionId], onDelete: Cascade, onUpdate: NoAction)
  status                Status?     @relation(fields: [statusId], references: [statusId], onUpdate: NoAction)
  feedbacks             Feedback[]
  images                Image[]
  qrCodes               QRCode[]

  @@unique([exhibitionId, sequence], map: "unique_exhibition_sequence")
  @@index([title], map: "idx_exhibit_title")
  @@index([createdAt], map: "idx_exhibit_created_at")
  @@index([exhibitionId, sequence], map: "idx_exhibition_sequence")
  @@map("exhibit")
}

model Audio {
  audioId      Int                @id @default(autoincrement()) @map("audio_id")
  exhibitId    BigInt?            @map("exhibit_id")
  languageId   BigInt?            @map("language_id")
  fileUrl      String?            @map("file_url") @db.VarChar(512)
  title        String?
  description  String?
  createdAt    DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  exhibit      Exhibit?           @relation(fields: [exhibitId], references: [exhibitId], onDelete: Cascade, onUpdate: NoAction)
  language     Language?          @relation(fields: [languageId], references: [languageId], onUpdate: NoAction)
  playbackLogs AudioPlaybackLog[]
  subtitles    Subtitle[]

  @@index([exhibitId], map: "idx_audio_exhibit_id")
  @@index([languageId], map: "idx_audio_language_id")
  @@index([title], map: "idx_audio_title")
  @@index([createdAt], map: "idx_audio_created_at")
  @@index([exhibitId, languageId], map: "idx_audio_exhibit_language")
  @@map("audio")
}

model AudioPlaybackLog {
  audioLogsId      Int       @id @default(autoincrement()) @map("audio_logs_id")
  userId           BigInt?   @map("user_id")
  audioId          Int?      @map("audio_id")
  audioStart       DateTime? @map("audio_start") @db.Timestamptz(6)
  audioEnd         DateTime? @map("audio_end") @db.Timestamptz(6)
  durationListened Int?      @map("duration_listened")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  audio            Audio?    @relation(fields: [audioId], references: [audioId], onDelete: Cascade, onUpdate: NoAction)
  user             User?     @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_audio_playback_logs_user_id")
  @@index([audioId], map: "idx_audio_playback_logs_audio_id")
  @@index([createdAt], map: "idx_audio_playback_logs_created_at")
  @@index([audioStart], map: "idx_audio_playback_logs_audio_start")
  @@map("audio_playback_logs")
}

model Feedback {
  feedbackId  BigInt    @id @default(autoincrement()) @map("feedback_id")
  userId      BigInt?   @map("user_id")
  exhibitId   BigInt?   @map("exhibit_id")
  rating      Int?
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  isHidden    Boolean   @default(false) @map("is_hidden")
  exhibit     Exhibit?  @relation(fields: [exhibitId], references: [exhibitId], onDelete: Cascade, onUpdate: NoAction)
  user        User?     @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_feedback_user_id")
  @@index([exhibitId], map: "idx_feedback_exhibit_id")
  @@index([rating], map: "idx_feedback_rating")
  @@index([createdAt], map: "idx_feedback_created_at")
  @@index([userId, exhibitId], map: "idx_feedback_user_exhibit")
  @@map("feedback")
}

model Image {
  imageId      BigInt      @id @default(autoincrement()) @map("image_id")
  exhibitId    BigInt?     @map("exhibit_id")
  exhibitionId BigInt?     @map("exhibition_id")
  title        String?
  description  String?
  fileUrl      String?     @map("file_url") @db.VarChar(512)
  isPrimary    Boolean?    @default(false) @map("is_primary")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  exhibit      Exhibit?    @relation(fields: [exhibitId], references: [exhibitId], onDelete: Cascade, onUpdate: NoAction)
  exhibition   Exhibition? @relation(fields: [exhibitionId], references: [exhibitionId], onDelete: Cascade, onUpdate: NoAction)

  @@index([exhibitId], map: "idx_images_exhibit_id")
  @@index([exhibitionId], map: "idx_images_exhibition_id")
  @@index([isPrimary], map: "idx_images_is_primary")
  @@index([title], map: "idx_images_title")
  @@map("images")
}

model QRCode {
  qrId      Int       @id @default(autoincrement()) @map("qr_id")
  exhibitId BigInt    @map("exhibit_id")
  qrUrl     String    @map("qr_url") @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  exhibit   Exhibit   @relation(fields: [exhibitId], references: [exhibitId], onDelete: Cascade, onUpdate: NoAction)

  @@index([exhibitId], map: "idx_qr_code_exhibit_id")
  @@index([qrUrl], map: "idx_qr_code_url")
  @@map("qr_code")
}

model Language {
  languageId BigInt     @id @default(autoincrement()) @map("language_id")
  statusId   Int?       @map("status_id")
  title      String     @db.VarChar(255)
  code       String     @unique @map("lang_code") @db.VarChar(10)
  isDefault  Boolean?   @default(false) @map("is_default")
  createdAt  DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?  @default(now()) @map("updated_at") @db.Timestamptz(6)
  audio      Audio[]
  status     Status?    @relation(fields: [statusId], references: [statusId], onUpdate: NoAction)
  subtitles  Subtitle[]

  @@index([statusId], map: "idx_language_status")
  @@index([code], map: "idx_language_code")
  @@index([title], map: "idx_language_title")
  @@index([isDefault], map: "idx_language_is_default")
  @@map("language")
}

model Permission {
  permissionId    Int              @id @default(autoincrement()) @map("permission_id")
  permissionName  String           @unique @map("permission_name") @db.VarChar(100)
  description     String?
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@index([permissionName], map: "idx_permissions_name")
  @@map("permissions")
}

model Role {
  roleId          Int              @id @default(autoincrement()) @map("role_id")
  roleName        String           @unique @map("role_name") @db.VarChar(50)
  description     String?
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([roleName], map: "idx_roles_name")
  @@map("roles")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade, onUpdate: NoAction)
  role         Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction)

  @@id([roleId, permissionId])
  @@index([roleId], map: "idx_roles_permission_role_id")
  @@index([permissionId], map: "idx_roles_permission_permission_id")
  @@map("roles_permission")
}

model Session {
  sessionId String    @id @default(dbgenerated("gen_random_uuid()")) @map("session_id") @db.Uuid
  userId    BigInt    @map("user_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_sessions_user_id")
  @@index([createdAt], map: "idx_sessions_created_at")
  @@map("sessions")
}

model Status {
  statusId    Int          @id @default(autoincrement()) @map("status_id")
  statusName  String       @unique @map("status_name") @db.VarChar(30)
  exhibits    Exhibit[]
  exhibitions Exhibition[]
  languages   Language[]
  users       User[]

  @@map("status")
}

model Subtitle {
  subtitleId BigInt    @id @default(autoincrement()) @map("subtitle_id")
  audioId    Int?      @map("audio_id")
  languageId BigInt?   @map("language_id")
  text       Json?
  createdBy  BigInt?   @map("created_by")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  audio      Audio?    @relation(fields: [audioId], references: [audioId], onDelete: Cascade, onUpdate: NoAction)
  user       User?     @relation(fields: [createdBy], references: [userId], onUpdate: NoAction)
  language   Language? @relation(fields: [languageId], references: [languageId], onUpdate: NoAction)

  @@index([audioId], map: "idx_subtitle_audio_id")
  @@index([languageId], map: "idx_subtitle_language_id")
  @@index([createdBy], map: "idx_subtitle_created_by")
  @@index([createdAt], map: "idx_subtitle_created_at")
  @@index([audioId, languageId], map: "idx_subtitle_audio_language")
  @@map("subtitle")
}

model User {
  userId                  BigInt                   @id @default(autoincrement()) @map("user_id")
  username                String                   @unique @db.VarChar(100)
  email                   String                   @unique @db.VarChar(100)
  passwordHash            String                   @map("password_hash") @db.VarChar(72)
  emailVerified           Boolean?                 @default(false) @map("email_verified")
  statusId                Int?                     @map("status_id")
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime?                @default(now()) @map("updated_at") @db.Timestamptz(6)
  playbackLogs            AudioPlaybackLog[]
  adminAudits             AuditLog[]               @relation("AdminUserAudits")
  targetAudits            AuditLog[]               @relation("TargetUserAudits")
  emailVerificationTokens EmailVerificationToken[]
  feedbacks               Feedback[]
  passwordResetTokens     PasswordResetToken[]
  sessions                Session[]
  subtitles               Subtitle[]
  status                  Status?                  @relation(fields: [statusId], references: [statusId], onUpdate: NoAction)
  userBadges              UserBadge[]
  roles                   UserRole[]

  @@index([statusId], map: "idx_user_status")
  @@index([username], map: "idx_user_username")
  @@index([email], map: "idx_user_email")
  @@index([createdAt], map: "idx_user_created_at")
  @@index([lastLoginAt], map: "idx_user_last_login")
  @@index([email, statusId], map: "idx_user_email_status")
  @@map("user")
}

model UserRole {
  userId    BigInt    @map("user_id")
  roleId    Int       @map("role_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role      @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction)
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, roleId])
  @@index([userId], map: "idx_userroles_user_id")
  @@index([roleId], map: "idx_userroles_role_id")
  @@map("userroles")
}

model AuditLog {
  auditLogId   BigInt    @id @default(autoincrement()) @map("audit_log_id")
  adminUserId  BigInt?   @map("admin_user_id")
  targetUserId BigInt?   @map("target_user_id")
  resource     String    @db.VarChar(50)
  action       String    @db.VarChar(50)
  changes      String?
  metadata     String?
  timestamp    DateTime? @default(now()) @db.Timestamptz(6)
  adminUser    User?     @relation("AdminUserAudits", fields: [adminUserId], references: [userId], onUpdate: NoAction)
  targetUser   User?     @relation("TargetUserAudits", fields: [targetUserId], references: [userId], onUpdate: NoAction)

  @@index([adminUserId], map: "idx_audit_logs_admin_user_id")
  @@index([targetUserId], map: "idx_audit_logs_target_user_id")
  @@index([resource], map: "idx_audit_logs_resource")
  @@index([action], map: "idx_audit_logs_action")
  @@index([timestamp], map: "idx_audit_logs_timestamp")
  @@map("audit_logs")
}

model PasswordResetToken {
  passwordResetId BigInt    @id @default(autoincrement()) @map("password_reset_id")
  userId          BigInt    @map("user_id")
  token           String    @unique @db.VarChar(255)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  user            User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "idx_password_reset_created_at")
  @@index([expiresAt], map: "idx_password_reset_expires_at")
  @@index([token], map: "idx_password_reset_token")
  @@index([userId], map: "idx_password_reset_user_id")
  @@map("password_reset_token")
}

model EmailVerificationToken {
  emailVerificationId BigInt    @id @default(autoincrement()) @map("email_verification_id")
  userId              BigInt    @map("user_id")
  token               String    @unique @db.VarChar(255)
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt           DateTime  @map("expires_at") @db.Timestamptz(6)
  user                User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "idx_email_verification_created_at")
  @@index([expiresAt], map: "idx_email_verification_expires_at")
  @@index([token], map: "idx_email_verification_token")
  @@index([userId], map: "idx_email_verification_user_id")
  @@map("email_verification_token")
}

model Badge {
  badgeId     BigInt      @id @default(autoincrement()) @map("badge_id")
  name        String?
  description String?
  imageUrl    String?     @map("image_url") @db.VarChar(512)
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  exhibit     Exhibit?    @relation("ExhibitToBadge")
  userBadges  UserBadge[]

  @@map("badge")
}

model UserBadge {
  userId    BigInt    @map("user_id")
  badgeId   BigInt    @map("badge_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  badge     Badge     @relation(fields: [badgeId], references: [badgeId], onDelete: Cascade, onUpdate: NoAction)
  user      User      @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, badgeId])
  @@map("user_badge")
}

model settings {
  key        String    @id
  value      Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}
